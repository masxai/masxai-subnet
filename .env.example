TASK_SOURCE=bt_forecast

# Centralized BT-Forecast FastAPI service used by neurons/validator.py.
# When BT_FORECAST_BASE_URL is set, validators fetch miner-safe questions from:
#   GET /v1/forecast-runs/{run_id}
#   GET /v1/forecast-runs/{run_id}/questions
#   GET /v1/resolutions?run_id={run_id}
# and post accurate resolved miner forecasts to:
#   POST /v1/miner-results
BT_FORECAST_BASE_URL=
BT_FORECAST_API_KEY=
BT_FORECAST_API_SECRET=
BT_FORECAST_BEARER_TOKEN=
BT_FORECAST_RUN_ID=
BT_FORECAST_RUN_DATE=
BT_FORECAST_INCLUDE_LINEAGE=false
BT_FORECAST_TIMEOUT=10
BT_FORECAST_MAX_RETRIES=3
BT_FORECAST_PAGE_SIZE=100
BT_FORECAST_POLL_INTERVAL_SECONDS=30
BT_FORECAST_MAX_CONCURRENT_REQUESTS=4
MASXAI_BT_FORECAST_REQUIRED=false
MASXAI_BT_FORECAST_MAX_QUESTIONS_PER_ROUND=12
MASXAI_BT_FORECAST_REISSUE_SECONDS=0
MASXAI_BT_FORECAST_RESOLUTION_WAIT_SECONDS=432000
MASXAI_BT_FORECAST_FEEDBACK_THRESHOLD=0.10
MASXAI_QUERY_VALIDATOR_UIDS=false
MASXAI_REQUIRE_VALIDATOR_PERMIT=false

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
LLM_TASKS_PER_BATCH=20
LLM_TASK_CATEGORY_MIX=bittensor,subnets,tao,validators,miners,governance

DB_PATH=./data/subnet.db

VALIDATOR_UID=
VALIDATOR_HOTKEY=
NETUID=1
SUBTENSOR_NETWORK=finney
WALLET_NAME=default
WALLET_HOTKEY=default
DRY_RUN_WEIGHTS=true

SIMULATE_MINERS=true
MINER_REGISTRY_PATH=./miners.json
MINER_QUERY_TIMEOUT_SECONDS=12
MINER_MAX_CONCURRENT_QUERIES=50
MINER_QUERY_INTERVAL_SECONDS=15

PERIOD_CHECK_INTERVAL_SECONDS=15
RESOLUTION_INTERVAL_SECONDS=30
WEIGHT_SET_INTERVAL_SECONDS=300
MANUAL_RESOLUTION_PATH=./data/manual_resolutions.json

EMA_ALPHA=0.2
CALIBRATION_ERROR_THRESHOLD=0.2
CALIBRATION_PENALTY_FACTOR=0.5
WEIGHT_SKILL=0.55
WEIGHT_RECENT_SKILL=0.25
WEIGHT_VALID_RATE=0.10
WEIGHT_PARTICIPATION=0.10

# Legacy MASXAI MVP settings still used by neurons/validator.py.
GEMINI_ENABLED=true
GEMINI_TIMEOUT=8
DISCORD_WEBHOOK_URL=
MASXAI_FALLBACK_TAO_PRICE_USD=
MASXAI_FORECAST_INTERVAL_SECONDS=300
